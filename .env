APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:fvS6doLp3QldtDDIUUdOi1bB67XwwQe+fLc+UodMA58=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
